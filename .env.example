APP_NAME=Bazaar
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# --- Docker / compose ---
# APP_PORT / FORWARD_*   host-side ports (change if they clash with another
#                        local stack; container-internal ports stay standard)
# WWW_UID/GID            host user mapped into php-fpm (matches bind-mount owner)
# MYSQL_*                consumed by the mysql service (see docker-compose.yml)
APP_PORT=8080
WWW_UID=1000
WWW_GID=1000
FORWARD_DB_PORT=3307
FORWARD_REDIS_PORT=6380
MYSQL_DATABASE=bazaar
MYSQL_USER=bazaar
MYSQL_PASSWORD=secret
MYSQL_ROOT_PASSWORD=root

# --- Database (Laravel reads these; host = mysql service name) ---
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=bazaar
DB_USERNAME=bazaar
DB_PASSWORD=secret

# --- Redis: cache, queue, session ---
REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

CACHE_STORE=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
QUEUE_CONNECTION=redis

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

MEMCACHED_HOST=127.0.0.1

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
